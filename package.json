{
  "name": "llm-gateway",
  "version": "2.0.0",
  "description": "Multi-provider LLM gateway with an admin dashboard. SQLite-backed providers, models, users, API keys and usage limits.",
  "main": "dist/index.js",
  "type": "commonjs",
  "scripts": {
    "dev": "concurrently -n gateway,web -c cyan,magenta \"npm:dev:gateway\" \"npm:dev:web\"",
    "dev:gateway": "tsx watch src/index.ts",
    "dev:web": "npm run dev --prefix web",
    "build": "npm run build:gateway && npm run build:web",
    "build:gateway": "tsc -p tsconfig.build.json",
    "build:web": "npm run build --prefix web",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "typecheck:web": "npm run typecheck --prefix web",
    "typecheck:all": "npm run typecheck && npm run typecheck:web"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "better-sqlite3": "^11.8.1",
    "express": "^4.21.2"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/express": "^5.0.6",
    "@types/node": "^26.0.0",
    "concurrently": "^9.1.2",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3"
  }
}
